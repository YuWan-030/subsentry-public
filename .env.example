SUBSENTRY_DB_TYPE=sqlite
SUBSENTRY_SQLITE_FILE=subsentry.db

# Set these before production deployment.
SUBSENTRY_SECRET_KEY=change-me-to-a-long-random-string
SUBSENTRY_CRON_TOKEN=change-me
SUBSENTRY_CORS_ORIGINS=*
SUBSENTRY_CORS_ALLOW_CREDENTIALS=true
SUBSENTRY_CSRF_ENABLED=true
SUBSENTRY_CSRF_TRUSTED_ORIGINS=
SUBSENTRY_SESSION_SAME_SITE=lax
SUBSENTRY_SESSION_HTTPS_ONLY=false
SUBSENTRY_ALLOW_PRIVATE_TARGETS=true

# Optional MySQL mode.
SUBSENTRY_MYSQL_HOST=127.0.0.1
SUBSENTRY_MYSQL_PORT=3306
SUBSENTRY_MYSQL_USER=subsentry
SUBSENTRY_MYSQL_PASSWORD=change-me
SUBSENTRY_MYSQL_DATABASE=subsentry

# Optional OnAuth integration.
SUBSENTRY_ONAUTH_BASE_URL=
SUBSENTRY_ONAUTH_CLIENT_ID=
SUBSENTRY_ONAUTH_CLIENT_SECRET=
SUBSENTRY_ONAUTH_SCOPE=read

# Optional Cloudflare Turnstile login protection.
SUBSENTRY_TURNSTILE_ENABLED=true
SUBSENTRY_TURNSTILE_SITE_KEY=
SUBSENTRY_TURNSTILE_SECRET_KEY=

# Optional subscription and notification settings.
SUBSENTRY_PUBLIC_SUBSCRIPTION_BASE_URL=http://127.0.0.1:10883
SUBSENTRY_DEFAULT_WEBHOOK_URL=
SUBSENTRY_NODE_PROBE_ENABLED=true
SUBSENTRY_NODE_PROBE_INTERVAL_SECONDS=300
